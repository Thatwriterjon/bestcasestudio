---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const learningPages = await getCollection('learning');

// Group pages by category (using folder names)
const grouped = learningPages.reduce((acc, page) => {
  const category = page.slug.split('/')[0];
  if (!acc[category]) acc[category] = [];
  acc[category].push(page);
  return acc;
}, {} as Record<string, typeof learningPages>);

// Sort categories and pages
const sortedCategories = Object.keys(grouped).sort();
---

<MainLayout
  title="Learning — Best Case Studio"
  description="Deep-dive guides on credibility signals: social proof, authority, brand presence, people, and process."
>
  <div class="w-full max-w-[1240px] mx-auto px-5 mt-[120px] mb-[120px]">

    <div class="mb-14">
      <h1 class="text-5xl lg:text-6xl font-medium leading-tight mb-4">Learning</h1>
      <p class="text-white/60 text-lg max-w-[560px]">
        Deep-dive guides on the five credibility signals: social proof, authority, brand presence, people, and process.
      </p>
    </div>

    {sortedCategories.map((category) => (
      <div class="mb-16">
        <h2 class="text-3xl font-medium leading-tight mb-6 capitalize">{category.replace(/-/g, ' ')}</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {grouped[category]?.map((page) => {
            const date = page.data.pubDate ? new Date(page.data.pubDate).toLocaleDateString('en-GB', {
              day: 'numeric', month: 'short', year: 'numeric',
            }) : null;

            return (
              <a
                href={`/learning/${page.slug}`}
                class="group flex flex-col bg-dark border border-white/10 rounded-[28px] overflow-hidden hover:border-pink/40 transition-colors p-6"
                data-page-slug={page.slug}
                data-page-title={page.data.title}
              >
                {page.data.tags && page.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {page.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="text-xs uppercase tracking-widest text-pink">{tag}</span>
                    ))}
                  </div>
                )}
                <h3 class="text-lg font-medium leading-snug mb-3 group-hover:text-pink transition-colors">
                  {page.data.title}
                </h3>
                <p class="text-white/60 text-sm leading-relaxed flex-1 mb-4">{page.data.summary}</p>
                {date && (
                  <div class="text-white/40 text-xs mt-auto pt-4 border-t border-white/10">
                    {date}
                  </div>
                )}
              </a>
            );
          })}
        </div>
      </div>
    ))}

  </div>
</MainLayout>

<script is:inline>
  document.querySelectorAll('a[data-page-slug]').forEach(function (link) {
    link.addEventListener('click', function () {
      window.posthog?.capture('learning_page_clicked', {
        page_slug: link.getAttribute('data-page-slug'),
        page_title: link.getAttribute('data-page-title'),
      });
    });
  });
</script>
