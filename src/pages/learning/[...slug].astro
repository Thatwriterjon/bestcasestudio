---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const learningPages = await getCollection('learning');

  return learningPages.map((page) => ({
    params: { slug: page.id.replace(/\.md$/, '') },
    props: { page },
  }));
}

interface Props {
  page: any;
}

const { page } = Astro.props as Props;
const { Content } = await page.render();
---

<MainLayout title={page.data.title + ' | Best Case Studio'} description={page.data.summary}>
  <div class="w-full max-w-[1240px] mx-auto px-5 mt-[120px] mb-[120px]">
    <article>
      <header class="mb-12">
        {page.data.type && (
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 bg-white/10 text-white/80 rounded-full text-xs font-medium uppercase tracking-widest">
              {page.data.type}
            </span>
          </div>
        )}
        <h1 class="text-5xl lg:text-6xl font-medium leading-tight mb-4">
          {page.data.title}
        </h1>
        <p class="text-white/60 text-lg max-w-[800px]">
          {page.data.summary}
        </p>
      </header>

      {page.data.image && (
        <figure class="mb-12 rounded-[28px] overflow-hidden">
          <img
            src={`/blog/${page.data.image}`}
            alt={page.data.title}
            class="w-full h-auto"
          />
        </figure>
      )}

      <div class="learning-content max-w-[720px] mb-12">
        <Content />
      </div>

      {page.data.tags && page.data.tags.length > 0 && (
        <footer class="border-t border-white/10 pt-8">
          <div class="flex gap-2 flex-wrap">
            {page.data.tags.map((tag: string) => (
              <a
                href={`/learning?tag=${encodeURIComponent(tag)}`}
                class="px-3 py-1 bg-white/5 text-white/60 rounded-full text-sm hover:bg-white/10 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        </footer>
      )}
    </article>
  </div>
</MainLayout>

<style is:global>
  .learning-content {
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.75;
  }

  .learning-content h2 {
    color: white;
    font-size: 1.875rem;
    font-weight: 600;
    margin-top: 1.5em;
    margin-bottom: 0.75em;
  }

  .learning-content h3 {
    color: white;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.25em;
    margin-bottom: 0.5em;
  }

  .learning-content p {
    margin-bottom: 1.25em;
  }

  .learning-content ul,
  .learning-content ol {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .learning-content li {
    margin-bottom: 0.5em;
  }

  .learning-content a {
    color: #fbbf24;
    text-decoration: none;
  }

  .learning-content a:hover {
    text-decoration: underline;
  }

  .learning-content code {
    background-color: rgba(255, 255, 255, 0.05);
    color: #fbbf24;
    padding: 0.25em 0.5em;
    border-radius: 0.25em;
    font-size: 0.9em;
  }

  .learning-content pre {
    background-color: rgba(255, 255, 255, 0.05);
    padding: 1em;
    border-radius: 0.5em;
    overflow-x: auto;
    margin-bottom: 1.25em;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .learning-content blockquote {
    border-left: 4px solid rgba(255, 255, 255, 0.2);
    padding-left: 1em;
    color: rgba(255, 255, 255, 0.7);
    font-style: italic;
  }

  .learning-content strong {
    font-weight: 600;
    color: white;
  }
</style>
