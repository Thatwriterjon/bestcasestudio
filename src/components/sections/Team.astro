---
import SectionTitle from "../ui/SectionTitle.astro";
import TeamCard from "../ui/TeamCard.astro";
import Section from "./Section.astro";

const description =
  "The small, focused team behind every Best Case Studio project.";

// Team images
import p1 from "../../assets/team/Jon.png";
import p2 from "../../assets/team/Alex.png";
import p3 from "../../assets/team/Jessie.png";

const team = [
  {
    pic: p1,
    name: "Jon",
    role: "Founder & Copywriter",
    description:
      "Jon has spent 7 years helping B2B SaaS companies with their copy, content, and positioning. He specialises in interviewing customers to uncover positioning insights that resonate with the right ICP.",
    link: "https://www.linkedin.com/in/thatwriterjon/",
  },
  {
    pic: p2,
    name: "Alex",
    role: "Videographer",
    description:
      "Alex handles all video production, filming, and editing. With years of experience creating professional video content, Alex ensures every case study looks polished and builds trust with your ideal customers.",
    link: "https://www.linkedin.com/in/alex-radford2/",
  },
  {
    pic: p3,
    name: "Jessie",
    role: "Customer Success",
    description:
      "Jessie keeps clients happy and everything running smoothly. Drawing on her Scrum Master background, she coordinates timelines, manages communication between all parties, and makes sure the process feels effortless from kickoff to final delivery.",
    link: "https://www.linkedin.com/in/jessie-mcgreevy-33b812100/",
  },
];
---

<Section id="about">
  <div class="mt-[140px] pb-[140px]">
    <SectionTitle sectionTitle="The Team" description={description} />
    <div
      class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-10"
    >
      {
        team.map((member, index) => (
          <TeamCard
            key={index}
            pic={member.pic}
            name={member.name}
            role={member.role}
            description={member.description}
            link={member.link}
          />
        ))
      }
    </div>
  </div>
</Section>
