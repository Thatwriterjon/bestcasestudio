---
import Card from "../ui/Card.astro";
import Section from "./Section.astro";
import SectionTitle from "../ui/SectionTitle.astro";

const steps = [
  {
    index: 1,
    title: "The Interview",
    description:
      "We interview your customers remotely, uncovering stories, quotes, and examples that will resonate with your ICP and support your positioning.",
  },
  {
    index: 2,
    title: "Editing & Writing",
    description:
      "We edit the video into multiple lengths for different uses, write a landing page for your website, and produce a shareable PDF.",
  },
  {
    index: 3,
    title: "Content Delivery",
    description:
      "Once you're happy, we hand over all the files. You own the content outright and can start sharing immediately.",
  },
];
---

<Section id="process">
  <div class="mt-[140px]">
    <SectionTitle
      sectionTitle="Our Process"
      description="Three steps from customer interview to ready-to-publish content."
    />
    <div class="flex flex-col lg:flex-row justify-between rounded-[45px] p-1 gap-[2px]">
      {
        steps.map((step) => (
          <Card>
            <div class="flex p-[60px] h-full bg-dark text-gray rounded-[45px] m-[1px]">
              <div class="flex flex-col gap-5">
                <span class="text-6xl text-zinc-600 font-bold leading-none">0{step.index}</span>
                <h3 class="text-2xl font-medium">{step.title}</h3>
                <p class="text-zinc-400 leading-relaxed">{step.description}</p>
              </div>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</Section>
