---
import Section from "./Section.astro";
import SectionTitle from "../ui/SectionTitle.astro";
---

<Section id="pricing">
  <div class="mt-[140px]">
  <SectionTitle
    sectionTitle="Pricing & Packages"
    description="One complete case study ecosystem — video, copy, and social assets. Pick the package that fits."
  />

  <div class="flex flex-col md:flex-row gap-8 mb-20">
    <!-- Single tier -->
    <div class="flex-1 bg-[#F3F3F3] border border-dark shadow-[0px_5px_0px_#191a23] rounded-[45px] p-10 flex flex-col">
      <h3 class="text-2xl font-medium mb-4">Single Full-Stack Case Study</h3>
      <p class="text-4xl font-bold">$3,000</p>
      <p class="text-sm text-zinc-500 mb-6">per case study</p>
      <ul class="flex flex-col gap-3 flex-1">
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> 1 video case study</li>
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> Short testimonial video</li>
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> 5 social videos</li>
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> Landing page copy</li>
      </ul>
      <p class="text-sm font-medium mt-4">Timeline: 2&ndash;3 weeks</p>
      <a
        href="https://calendly.com/thatwriterjon/best-case-studio"
        class="btn-primary mt-6 inline-block text-center"
      >Book Discovery Call</a>
    </div>

    <!-- Trio tier -->
    <div class="flex-1 bg-yellow border border-dark shadow-[0px_5px_0px_#191a23] rounded-[45px] p-10 flex flex-col">
      <h3 class="text-2xl font-medium mb-4">Trio of Full-Stack Case Studies</h3>
      <p class="text-4xl font-bold">$7,500</p>
      <p class="text-sm mb-6">$2,500 per case study</p>
      <ul class="flex flex-col gap-3 flex-1">
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> 3 video case studies</li>
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> 3 short testimonial videos</li>
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> 15 social videos</li>
        <li class="flex items-start gap-2"><span class="font-bold">&#10003;</span> 3 &times; landing page copy</li>
      </ul>
      <p class="text-sm font-medium mt-4">Timeline: 3&ndash;6 weeks</p>
      <a
        href="https://calendly.com/thatwriterjon/best-case-studio"
        class="btn-primary mt-6 inline-block text-center"
      >Book Discovery Call</a>
    </div>
  </div>
  </div>
</Section>
