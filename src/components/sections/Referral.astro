---
import Section from "./Section.astro";
import SectionTitle from "../ui/SectionTitle.astro";
---

<Section id="referral">
  <div class="mt-[140px] mb-[140px]">
    <SectionTitle
      sectionTitle="$500 Referral Bounty"
      description="Know a B2B SaaS company that needs case studies? Refer them to us."
    />
    <div class="max-w-[680px]">
      <p class="text-lg mb-6">
        If you refer a B2B SaaS company and they become a client, we'll send you
        <strong>$500 cash</strong> when they make their first payment.
      </p>
      <ul class="space-y-3 list-none">
        <li class="flex items-start gap-3">
          <span class="text-pink font-bold">—</span>
          <span>No cap on referrals — refer ten companies, earn $5,000.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-pink font-bold">—</span>
          <span>No forms to fill. Just make the introduction.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-pink font-bold">—</span>
          <span>Payment sent when the referred company pays their first invoice.</span>
        </li>
      </ul>
      <p class="mt-8 text-zinc-500 text-sm">
        To refer someone, email jon@bestcasestud.io with the subject line "Referral" and tell us who to expect.
      </p>
    </div>
  </div>
</Section>
