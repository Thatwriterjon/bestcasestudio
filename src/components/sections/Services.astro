---
import SectionTitle from "../ui/SectionTitle.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import Section from "./Section.astro";

import c1 from "../../assets/pics/card-pic1.png";
import c2 from "../../assets/pics/card-pic2.png";
import c3 from "../../assets/pics/card-pic3.png";

const cards = [
  {
    index: 1,
    titleTop: "Build",
    titleBottom: "Trust",
    img: c1,
    alt: "Build Trust",
    link: "#pricing",
  },
  {
    index: 2,
    titleTop: "Improve SEO",
    titleBottom: "& GEO",
    img: c2,
    alt: "Improve SEO and GEO",
    link: "#pricing",
  },
  {
    index: 3,
    titleTop: "Lower",
    titleBottom: "CAC",
    img: c3,
    alt: "Lower CAC",
    link: "#pricing",
  },
];

const description =
  "Case studies are one of the highest-performing content types for B2B SaaS. Here's what they can do for you.";
---

<Section id="services">
  <div class="mt-[140px] mb-5">
    <SectionTitle sectionTitle="Why Case Studies?" description={description} />
    <div class="grid lg:grid-cols-3 gap-10">
      {
        cards.map((card) => (
          <ServiceCard
            index={card.index}
            titleTop={card.titleTop}
            titleBottom={card.titleBottom}
            img={card.img}
            alt={card.alt}
            link={card.link}
          />
        ))
      }
    </div>
  </div>
</Section>
