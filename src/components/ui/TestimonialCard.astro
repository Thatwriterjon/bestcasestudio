---
import { Image } from "astro:assets";

const { name, role, comment, avatar } = Astro.props;
const avatarImage = avatar ? (await avatar()).default : null;
---

<div class="rounded-[45px] border border-gray bg-gray p-10 flex flex-col gap-6 h-full">
  <p class="text-white opacity-80 leading-relaxed text-base flex-1">"{comment}"</p>
  <div class="flex items-center gap-4 pt-4 border-t border-white/10">
    {avatarImage && (
      <Image
        src={avatarImage}
        alt={name}
        width={48}
        height={48}
        class="w-12 h-12 rounded-full object-cover flex-shrink-0"
      />
    )}
    <div class="flex flex-col gap-0.5">
      <span class="text-white font-medium">{name}</span>
      <span class="text-white/50 text-sm">{role}</span>
    </div>
  </div>
</div>
