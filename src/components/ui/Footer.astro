---
import { Image } from "astro:assets";
import Logo from "../../assets/alt-logo.svg";

const links = [
  { name: "Services", href: "#services" },
  { name: "Pricing", href: "#pricing" },
  { name: "Process", href: "#process" },
  { name: "FAQ", href: "#faq" },
];

const socials = [
  { name: "LinkedIn", href: "https://www.linkedin.com/in/jonmcgreevy/", label: "Jon McGreevy on LinkedIn" },
  { name: "Substack", href: "https://jonmcgreevy.substack.com", label: "Jon McGreevy on Substack" },
  { name: "Spotify", href: "https://open.spotify.com/show/6mH42FJY0OA3CNiMAIj4cN", label: "Best Case Studio on Spotify" },
  { name: "Apple Podcasts", href: "https://podcasts.apple.com/us/podcast/saasy-as-f-k-podcast/id1573388272", label: "Best Case Studio on Apple Podcasts" },
];
---

<section class="sm:px-5">
  <div class="w-full max-w-[1240px] mx-auto">
    <div class="px-[15px] bg-dark text-gray py-[55px] lg:px-[60px] sm:rounded-t-[45px]">

      <!-- Top row: logo | nav links | social links -->
      <div class="flex flex-col lg:flex-row gap-7 items-center justify-between">
        <picture>
          <a href="#home">
            <Image src={Logo} alt="Best Case Studio logo" />
          </a>
        </picture>

        <ul class="flex flex-col sm:flex-row gap-5">
          {links.map((link) => (
            <li class="text-center">
              <a class="underline" href={link.href}>{link.name}</a>
            </li>
          ))}
        </ul>

        <ul class="flex flex-wrap gap-4">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="text-xs uppercase tracking-widest text-gray hover:text-pink transition-colors"
              >
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Divider -->
      <div class="h-[1px] bg-gray mt-[51px] mb-5"></div>

      <!-- Copyright row -->
      <div class="flex justify-center md:justify-between text-center">
        <span>© {new Date().getFullYear()} Best Case Studio. All rights reserved.</span>
      </div>

    </div>
  </div>
</section>
