---
import AccordionItem from "./AccordionItem.astro";

const content = [
{
  index: 1,
  title: "The Interview",
  description: "We interview your customers remotely, uncovering stories, quotes, and examples that will resonate with your ICP and support your positioning."
},
{
  index: 2,
  title: "Editing & Writing",
  description: "Based on this interview, we'll edit the video down into a few different lengths for different uses. We'll also write a landing page for your website and a shareable PDF."
},
{
  index: 3,
  title: "Content Delivery",
  description: "Once you're happy with the content, we share all the files with you. You then have full ownership of the case study content, and can start sharing them and adding them to your website immediately."
}
];
---

{
  content.map((item) => {
    return (
      <AccordionItem
        index={item.index}
        title={item.title}
        description={item.description}
      />
    );
  })
}
